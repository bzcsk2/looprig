{
  "name": "@covalo/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "covalo": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@covalo/core": "workspace:*",
    "@covalo/tools": "workspace:*",
    "@covalo/mcp": "workspace:*",
    "@covalo/tui": "workspace:*",
    "@covalo/plugin": "workspace:*",
    "@covalo/memory": "workspace:*",
    "smol-toml": "^1.7.0"
  }
}
