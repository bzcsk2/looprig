{
  "name": "@deepreef/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "deepreef": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@deepreef/core": "workspace:*",
    "@deepreef/tools": "workspace:*",
    "@deepreef/mcp": "workspace:*",
    "@deepreef/tui": "workspace:*",
    "@deepreef/plugin": "workspace:*",
    "@deepreef/memory": "workspace:*",
    "@deepreef/tui-opentui": "workspace:*",
    "@opentui/core": "link:@opentui/core",
    "@opentui/react": "link:@opentui/react"
  }
}
