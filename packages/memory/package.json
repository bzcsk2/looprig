{
  "name": "@covalo/memory",
  "version": "0.1.0",
  "description": "AgentMemory integrated as Covalo native memory — persistent memory for AI coding agents",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./runtime": {
      "types": "./src/runtime/index.ts",
      "import": "./src/runtime/index.ts"
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "test:bun": "bun test"
  },
  "keywords": ["Covalo", "memory", "agent", "persistent"],
  "license": "Apache-2.0",
  "dependencies": {
    "@covalo/core": "workspace:*",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "*",
    "@anthropic-ai/claude-agent-sdk": "*",
    "@xenova/transformers": "*"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@anthropic-ai/claude-agent-sdk": {
      "optional": true
    },
    "@xenova/transformers": {
      "optional": true
    }
  }
}
