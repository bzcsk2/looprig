{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "declaration": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "lib": ["ES2023"],
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@anthropic/ink": ["./packages/ink/src/index.ts"],
      "@anthropic/ink/*": ["./packages/ink/src/*"],
      "@covalo/core": ["./packages/core/src/index.ts"],
      "@covalo/core/*": ["./packages/core/src/*"],
      "@covalo/ink": ["./packages/ink/src/index.ts"],
      "@covalo/ink/*": ["./packages/ink/src/*"],
      "@covalo/security": ["./packages/security/src/index.ts"],
      "@covalo/security/*": ["./packages/security/src/*"],
      "@covalo/mcp": ["./packages/mcp/src/index.ts"],
      "@covalo/mcp/*": ["./packages/mcp/src/*"],
      "@covalo/tools": ["./packages/tools/src/index.ts"],
      "@covalo/tools/*": ["./packages/tools/src/*"],
      "@covalo/tui": ["./packages/tui/src/index.ts"],
      "@covalo/tui/*": ["./packages/tui/src/*"],
      "@covalo/memory": ["./packages/memory/src/index.ts"],
      "@covalo/memory/*": ["./packages/memory/src/*"],
      "@covalo/plugin": ["./packages/plugin/src/index.ts"],
      "@covalo/plugin/*": ["./packages/plugin/src/*"],
      "@covalo/shell": ["./packages/shell/src/index.ts"],
      "@covalo/shell/*": ["./packages/shell/src/*"]
    }
  },
  "include": ["packages/*/src/**/*.ts", "packages/*/src/**/*.tsx", "types/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "**/__tests__/**", "packages/tools/src/skills/**", "packages/core/src/eval/fixtures/**"]
}
